@model Firma.Data.Data.Hotel.RoomType

@{
    ViewData["Title"] = "Usuń typ pokoju";
}

<div class="view-container">
    <div class="row justify-content-center">

        <div class="col-md-12">
            
            <div class="header-row">
                <div class="title-group">
                    <i class="bi bi-tags-fill"></i>
                    <h1>Usuń typ pokoju</h1>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center gap-2 backBtn">
                    <i class="bi bi-arrow-left"></i> POWRÓT
                </a>
            </div>
            
            <div class="form-card">
                <h4 class="text-danger mb-4">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>Czy na pewno chcesz usunąć ten typ pokoju?
                </h4>
            <div class="row">
                <div class="col-md-6">
                    <h5 class="section-title"><i class="bi bi-info-circle me-2"></i>Dane podstawowe</h5>
                
                    <div class="form-group mb-3">
                        <label class="control-label fw-bold mb-1">@Html.DisplayNameFor(model => model.Name)</label>
                        <div class="form-control input-area d-flex align-items-center">
                            @Html.DisplayFor(model => model.Name)
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label class="control-label fw-bold mb-1">@Html.DisplayNameFor(model => model.BasePrice)</label>
                        <div class="input-group">
                            <div class="form-control input-area d-flex align-items-center price-cell">
                                @Html.DisplayFor(model => model.BasePrice)
                            </div>
                            <span class="input-group-text url-addon">ZŁ</span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 form-group mb-3">
                            <label class="control-label fw-bold mb-1">@Html.DisplayNameFor(model => model.MaxGuests)</label>
                            <div class="form-control input-area d-flex align-items-center">
                                @Html.DisplayFor(model => model.MaxGuests)
                            </div>
                        </div>
                        <div class="col-md-6 form-group mb-3">
                            <label class="control-label fw-bold mb-1">@Html.DisplayNameFor(model => model.BedCount)</label>
                            <div class="form-control input-area d-flex align-items-center">
                                @Html.DisplayFor(model => model.BedCount)
                            </div>
                        </div>
                    </div>
                    <div class="form-group mb-4 mt-3">
                        <label class="control-label fw-bold mb-1">@Html.DisplayNameFor(model => model.Description)</label>
                        <textarea class="form-control input-area" rows="5" readonly>@Model.Description</textarea>
                    </div>
                </div>
                <div class="col-md-6">
                    <h5 class="section-title"><i class="bi bi-image me-2"></i>Podgląd zdjęcia</h5>
                
                    <div class="form-group mb-5">
                        <label class="control-label fw-bold mb-1">@Html.DisplayNameFor(model => model.PhotoUrl)</label>
                        <div class="form-control input-area d-flex align-items-center text-truncate mb-3" title="@Model.PhotoUrl">
                            @(Model.PhotoUrl)
                        </div>
                    </div>

                    <div class="photo-preview-box rounded border shadow-sm d-flex align-items-center justify-content-center overflow-hidden">
                        @{
                        
                            var fileExists = File.Exists($"/images/{Model.PhotoUrl}");
                            var imgSrc = fileExists ? $"/images/{Model.PhotoUrl}" : "/images/default-room-image.jpg";
                        }
                        <img src="@imgSrc" class="img-fluid w-100 photo-preview-img" />
                    </div>
                     
                </div>
                
            </div>

                <hr class="my-4 segment-divider" />

                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    
                    <div class="d-flex justify-content-end align-items-center gap-3">
                        <a asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center gap-2 backBtn">
                            <i class="bi bi-arrow-left"></i> Anuluj
                        </a>
                        <button type="submit" class="btn btn-danger d-flex align-items-center gap-2 border-0 fw-bold px-4 py-2" style="border-radius: 6px;">
                            <i class="bi bi-trash me-1"></i> USUŃ
                        </button>
                    </div>
                </form>
                
            </div>

        </div>
    </div>
</div>