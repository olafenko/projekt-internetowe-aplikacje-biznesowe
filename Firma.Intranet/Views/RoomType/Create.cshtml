@model Firma.Data.Data.Hotel.RoomType

@{
    ViewData["Title"] = "Dodaj typ pokoju";
}

<div class="view-container">
    <div class="header-row">
        <div class="title-group">
            <i class="bi bi-tags-fill"></i>
            <h1>Dodaj typ pokoju</h1>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center gap-2 backBtn">
            <i class="bi bi-arrow-left"></i> POWRÓT
        </a>
    </div>

    <div class="form-card">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row gx-5">
                <div class="col-lg-6 mb-4">
                    <h5 class="section-title"><i class="bi bi-info-circle me-2"></i>Dane podstawowe</h5>
                    
                    <div class="form-group mb-3">
                        <label asp-for="Name" class="control-label fw-bold mb-1">Nazwa typu pokoju</label>
                        <input asp-for="Name" class="form-control input-area" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="BasePrice" class="control-label fw-bold mb-1">Cena bazowa</label>
                        <div class="input-group">
                            <input asp-for="BasePrice" class="form-control input-area" />
                            <span class="input-group-text url-addon">ZŁ</span>
                        </div>
                        <span asp-validation-for="BasePrice" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 form-group mb-3">
                            <label asp-for="MaxGuests" class="control-label fw-bold mb-1">Maks. liczba gości</label>
                            <input asp-for="MaxGuests" class="form-control input-area" />
                            <span asp-validation-for="MaxGuests" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 form-group mb-3">
                            <label asp-for="BedCount" class="control-label fw-bold mb-1">Liczba łóżek</label>
                            <input asp-for="BedCount" class="form-control input-area" />
                            <span asp-validation-for="BedCount" class="text-danger small"></span>
                        </div>
                        
                    </div>
                </div>

                <div class="col-lg-6 mb-4">
                    <h5 class="section-title"><i class="bi bi-card-text me-2"></i>Opis i zdjęcie</h5>
                    <div class="form-group mb-4">
                        <label asp-for="PhotoUrl" class="control-label fw-bold mb-1">URL Zdjęcia</label>

                        <div class="input-group">
                            <span class="input-group-text url-addon"><i class="bi bi-link-45deg"></i></span>
                            <input asp-for="PhotoUrl" class="form-control input-area" />
                        </div>

                        <span asp-validation-for="PhotoUrl" class="text-danger small"></span>
                    </div>
                    <div class="form-group mb-3 mt-2">
                        <textarea asp-for="Description" class="form-control input-area" rows="5"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <hr class="my-4 segment-divider" />

            <div class="d-flex justify-content-end align-items-center gap-3">
                <a asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center gap-2 backBtn">
                    <i class="bi bi-arrow-left"></i> Anuluj
                </a>
                <button type="submit" class="createBtn border-0">
                    <i class="bi bi-check-lg me-1"></i> ZAPISZ TYP POKOJU
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}