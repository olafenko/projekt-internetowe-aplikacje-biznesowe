@model Firma.Data.Data.Hotel.Reservation

@{
    ViewData["Title"] = "Dodaj rezerwację";
}

<div class="view-container">
    <div class="row justify-content-center">

        <div class="col-8">
            
            <div class="header-row">
                <div class="title-group">
                    <i class="bi bi-calendar-plus"></i>
                    <h1>Dodaj rezerwację</h1>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center gap-2 backBtn">
                    <i class="bi bi-arrow-left"></i> POWRÓT
                </a>
            </div>

            <div class="form-card">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <h5 class="section-title"><i class="bi bi-calendar-range me-2"></i>Daty pobytu</h5>
                    
                    <div class="row">
                        <div class="col-md-6 form-group mb-3">
                            <label asp-for="CheckInDate" class="control-label fw-bold mb-1"></label>
                            <input asp-for="CheckInDate" class="form-control input-area" type="date" />
                            <span asp-validation-for="CheckInDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 form-group mb-3">
                            <label asp-for="CheckOutDate" class="control-label fw-bold mb-1"></label>
                            <input asp-for="CheckOutDate" class="form-control input-area" type="date" />
                            <span asp-validation-for="CheckOutDate" class="text-danger small"></span>
                        </div>
                    </div>

                    <h5 class="section-title mt-4"><i class="bi bi-door-open me-2"></i>Szczegóły rezerwacji</h5>

                    <div class="row">
                        <div class="col-6 form-group mb-3">
                            <label asp-for="GuestId" class="control-label fw-bold mb-1"></label>
                            <select asp-for="GuestId" class="form-select input-area" asp-items="ViewBag.GuestId">
                                <option value="">-- Wybierz Gościa --</option>
                            </select>
                            <span asp-validation-for="GuestId" class="text-danger small"></span>
                        </div>

                        <div class="col-6 form-group mb-4">
                            <label asp-for="RoomId" class="control-label fw-bold mb-1"></label>
                            <select asp-for="RoomId" class="form-select input-area" asp-items="ViewBag.RoomId">
                                <option value="">-- Wybierz Pokój --</option>
                            </select>
                            <span asp-validation-for="RoomId" class="text-danger small"></span>
                        </div>
                    </div>
                    
                    <h5 class="section-title"><i class="bi bi-people me-2"></i>Liczba osób</h5>

                    <div class="row">
                        <div class="col-6 form-group mb-3">
                            <label asp-for="AdultCount" class="control-label fw-bold mb-1"></label>
                            <input asp-for="AdultCount" class="form-control input-area" min="1" value="1" />
                            <span asp-validation-for="AdultCount" class="text-danger small"></span>
                        </div>

                        <div class="col-6 form-group mb-3">
                            <label asp-for="ChildCount" class="control-label fw-bold mb-1"></label>
                            <input asp-for="ChildCount" class="form-control input-area" min="0" value="0" />
                            <span asp-validation-for="ChildCount" class="text-danger small"></span>
                        </div>
                    </div>

                    <hr class="my-4 segment-divider" />

                    <div class="d-flex justify-content-end align-items-center gap-3">
                        <a asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center gap-2 backBtn">
                            <i class="bi bi-arrow-left"></i> Anuluj
                        </a>
                        <button type="submit" class="createBtn border-0">
                            <i class="bi bi-check-lg me-1"></i> ZAPISZ
                        </button>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}