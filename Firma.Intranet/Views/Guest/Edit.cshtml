@model Firma.Data.Data.Hotel.Guest

@{
    ViewData["Title"] = "Edytuj gościa";
}

<div class="view-container">
    <div class="row justify-content-center">

        <div class="col-8">
            
            <div class="header-row">
                <div class="title-group">
                    <i class="bi bi-pencil-square"></i>
                    <h1>Edytuj gościa</h1>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center gap-2 backBtn">
                    <i class="bi bi-arrow-left"></i> POWRÓT
                </a>
            </div>

            <div class="form-card">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <input type="hidden" asp-for="Id" />

                    <h5 class="section-title"><i class="bi bi-person me-2"></i>Dane osobowe</h5>
                    
                    <div class="row">
                        <div class="col-md-6 form-group mb-3">
                            <label asp-for="Name" class="control-label fw-bold mb-1"></label>
                            <input asp-for="Name" class="form-control input-area" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 form-group mb-3">
                            <label asp-for="LastName" class="control-label fw-bold mb-1"></label>
                            <input asp-for="LastName" class="form-control input-area" />
                            <span asp-validation-for="LastName" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-6 form-group mb-3">
                            <label asp-for="Email" class="control-label fw-bold mb-1"></label>
                            <input asp-for="Email" class="form-control input-area" type="email" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="col-6 form-group mb-4">
                            <label asp-for="PhoneNumber" class="control-label fw-bold mb-1"></label>
                            <input asp-for="PhoneNumber" class="form-control input-area" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-6 form-group mb-3">
                            <label asp-for="IdentityCardNumber" class="control-label fw-bold mb-1"></label>
                            <input asp-for="IdentityCardNumber" class="form-control input-area" />
                            <span asp-validation-for="IdentityCardNumber" class="text-danger small"></span>
                        </div>

                        <div class="col-6 form-group mb-3">
                            <label asp-for="Country" class="control-label fw-bold mb-1"></label>
                            <input asp-for="Country" class="form-control input-area" />
                            <span asp-validation-for="Country" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="form-group mb-4 mt-3">
                        <label asp-for="Notes" class="control-label fw-bold mb-1"></label>
                        <textarea asp-for="Notes" class="form-control input-area" rows="4"></textarea>
                        <span asp-validation-for="Notes" class="text-danger small"></span>
                    </div>

                    <hr class="my-4 segment-divider" />

                    <div class="d-flex justify-content-end align-items-center gap-3">
                        <a asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center gap-2 backBtn">
                            <i class="bi bi-arrow-left"></i> Anuluj
                        </a>
                        <button type="submit" class="createBtn border-0">
                            <i class="bi bi-check-lg me-1"></i> ZAPISZ
                        </button>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}