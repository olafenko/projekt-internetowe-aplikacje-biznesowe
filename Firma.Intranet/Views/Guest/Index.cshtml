@model IEnumerable<Firma.Data.Data.Hotel.Guest>

@{
    ViewData["Title"] = "Goście";
}

<div class="view-container">
    <div class="header-row">
        <div class="title-group">
            <i class="bi bi-people-fill"></i>
            <h1>Baza gości</h1>
        </div>
        <a class="createBtn" asp-action="Create">
            <i class="bi bi-plus-lg"></i> DODAJ GOŚCIA
        </a>
    </div>

    <div class="filter-bar">
        <div class="filter-content">
            <i class="bi bi-funnel"></i>
            <span>SORTOWANIE I FILTROWANIE</span>
        </div>
    </div>

    <div class="table-card">
        <table class="table main-table">
            <thead>
                <tr>
                    <th><i class="bi bi-person me-2"></i>@Html.DisplayNameFor(model => model.Name)</th>
                    <th><i class="bi bi-person-badge me-2"></i>@Html.DisplayNameFor(model => model.LastName)</th>
                    <th><i class="bi bi-envelope me-2"></i>@Html.DisplayNameFor(model => model.Email)</th>
                    <th><i class="bi bi-globe me-2"></i>@Html.DisplayNameFor(model => model.Country)</th>
                    <th><i class="bi bi-telephone me-2"></i>@Html.DisplayNameFor(model => model.PhoneNumber)</th>
                    <th><i class="bi bi-card-text me-2"></i>@Html.DisplayNameFor(model => model.IdentityCardNumber)</th>
                    <th><i class="bi bi-justify-left me-2"></i>@Html.DisplayNameFor(model => model.Notes)</th>
                    <th><i class="bi bi-activity me-2"></i>Status</th>
                    <th class="text-center px-4">Akcje</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.Name)</td>
                        <td class="fw-bold">@Html.DisplayFor(modelItem => item.LastName)</td>
                        <td class="email">@Html.DisplayFor(modelItem => item.Email)</td>
                        <td>@Html.DisplayFor(modelItem => item.Country)</td>
                        <td class="text-muted-custom">@Html.DisplayFor(modelItem => item.PhoneNumber)</td>
                        <td class="text-muted-custom">@Html.DisplayFor(modelItem => item.IdentityCardNumber)</td>
                        <td class="text-truncate text-muted-custom" style="max-width: 150px;">@Html.DisplayFor(modelItem => item.Notes)</td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="status-badge active">Aktywny</span>
                            }
                            else
                            {
                                <span class="status-badge inactive">Nieaktywny</span>
                            }
                        </td>
                        <td class="text-end px-4">
                            <div class="action-buttons">
                                <a asp-action="Edit" asp-route-id="@item.Id" title="Edytuj" class="edit-btn">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <a asp-action="Details" asp-route-id="@item.Id" title="Szczegóły" class="details-btn">
                                    <i class="bi bi-info-circle"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" title="Usuń" class="delete-btn">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>