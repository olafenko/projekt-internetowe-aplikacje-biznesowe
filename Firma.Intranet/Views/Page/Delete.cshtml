@model Firma.Data.Data.CMS.Page

@{
    ViewData["Title"] = "Usuń stronę";
}

<div class="view-container">
    <div class="row justify-content-center">

        <div class="col-8">
            
            <div class="header-row">
                <div class="title-group">
                    <i class="bi bi-file-text"></i>
                    <h1>Usuń stronę</h1>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center gap-2 backBtn">
                    <i class="bi bi-arrow-left"></i> POWRÓT
                </a>
            </div>

            <div class="form-card">
                
                <h4 class="text-danger mb-4">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>Czy na pewno chcesz usunąć tę stronę?
                </h4>

                <h5 class="section-title"><i class="bi bi-info-circle me-2"></i>Dane podstawowe strony</h5>
                
                <div class="row">
                    <div class="col-md-6 form-group mb-3">
                        <label class="control-label fw-bold mb-1">@Html.DisplayNameFor(model => model.Title)</label>
                        <div class="form-control input-area d-flex align-items-center">
                            @Html.DisplayFor(model => model.Title)
                        </div>
                    </div>

                    <div class="col-md-6 form-group mb-3">
                        <label class="control-label fw-bold mb-1">@Html.DisplayNameFor(model => model.LinkTitle)</label>
                        <div class="form-control input-area d-flex align-items-center">
                            @Html.DisplayFor(model => model.LinkTitle)
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 form-group mb-3">
                        <label class="control-label fw-bold mb-1">@Html.DisplayNameFor(model => model.Position)</label>
                        <div class="form-control input-area d-flex align-items-center">
                            @Html.DisplayFor(model => model.Position)
                        </div>
                    </div>

                    <div class="col-md-6 form-group mb-3">
                        <label class="control-label fw-bold mb-1">@Html.DisplayNameFor(model => model.PageMenuArea)</label>
                        <div class="form-control input-area d-flex align-items-center">
                            @Html.DisplayFor(model => model.PageMenuArea)
                        </div>
                    </div>
                </div>

                <div class="form-group mb-4 mt-2">
                    <label class="control-label fw-bold mb-1">@Html.DisplayNameFor(model => model.IsLinkCTA)</label>
                    <div class="d-flex align-items-center gap-2 ps-1">
                        @if (Model.IsLinkCTA)
                        {
                            <i class="bi bi-check-square-fill text-primary fs-5"></i>
                            <span>TAK</span>
                        }
                        else
                        {
                            <i class="bi bi-square fs-5 text-muted"></i>
                            <span>NIE</span>
                        }
                    </div>
                </div>

                <h5 class="section-title mt-4"><i class="bi bi-layout-text-window-reverse me-2"></i>Treść strony</h5>

                <div class="form-group mb-4">
                    <label class="control-label fw-bold mb-1">@Html.DisplayNameFor(model => model.Content)</label>
                    <textarea class="form-control input-area" rows="6" readonly>@Model.Content</textarea>
                </div>

                <hr class="my-4 segment-divider" />

                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    
                    <div class="d-flex justify-content-end align-items-center gap-3">
                        <a asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center gap-2 backBtn">
                            <i class="bi bi-arrow-left"></i> Anuluj
                        </a>
                        <button type="submit" class="btn btn-danger d-flex align-items-center gap-2 border-0 fw-bold px-4 py-2 rounded">
                            <i class="bi bi-trash me-1"></i> USUŃ
                        </button>
                    </div>
                </form>
                
            </div>

        </div>
    </div>
</div>