@model IEnumerable<Firma.Data.Data.CMS.Page>

@{
    ViewData["Title"] = "Strony CMS";
}

<div class="view-container">
    <div class="header-row">
        <div class="title-group">
            <i class="bi bi-file-text"></i>
            <h1>Strony</h1>
        </div>
        <a class="createBtn" asp-action="Create">
            <i class="bi bi-plus-lg"></i> DODAJ STRONĘ
        </a>
    </div>

    <div class="filter-bar">
        <div class="filter-content">
            <i class="bi bi-funnel"></i>
            <span>SORTOWANIE I FILTROWANIE</span>
        </div>
    </div>

    <div class="table-card">
        <table class="table main-table">
            <thead>
                <tr>
                    <th><i class="bi bi-fonts me-2"></i>@Html.DisplayNameFor(model => model.Title)</th>
                    <th><i class="bi bi-link-45deg me-2"></i>@Html.DisplayNameFor(model => model.LinkTitle)</th>
                    <th><i class="bi bi-sort-numeric-down me-2"></i>@Html.DisplayNameFor(model => model.Position)</th>
                    <th><i class="bi bi-layout-sidebar me-2"></i>@Html.DisplayNameFor(model => model.PageMenuArea)</th>
                    <th><i class="bi bi-image me-2"></i>@Html.DisplayNameFor(model => model.HeroPhotoUrl)</th>
                    <th>@Html.DisplayNameFor(model => model.IsLinkCTA)</th>
                    <th><i class="bi bi-activity me-2"></i>Status</th>
                    <th class="text-center px-4">Akcje</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold">@Html.DisplayFor(modelItem => item.Title)</td>
                        <td>@Html.DisplayFor(modelItem => item.LinkTitle)</td>
                        <td class="fw-bold">@Html.DisplayFor(modelItem => item.Position)</td>
                        <td>@Html.DisplayFor(modelItem => item.PageMenuArea)</td>
                        <td>@Html.DisplayFor(modelItem => item.HeroPhotoUrl)</td>
                        <td>
                            @if (item.IsLinkCTA)
                            {
                                <span class="status-badge">TAK</span>
                            }
                            else
                            {
                                <span class="status-badge">NIE</span>
                            }
                        </td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="status-badge active">Aktywna</span>
                            }
                            else
                            {
                                <span class="status-badge inactive">Nieaktywna</span>
                            }
                        </td>
                        <td class="text-end px-4">
                            <div class="action-buttons">
                                <a asp-action="Edit" asp-route-id="@item.Id" title="Edytuj" class="edit-btn">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <a asp-action="Details" asp-route-id="@item.Id" title="Szczegóły" class="details-btn">
                                    <i class="bi bi-info-circle"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" title="Usuń" class="delete-btn">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>