@using Firma.Data.Data.CMS.Enums
@model Firma.Data.Data.CMS.Page

@{
    ViewData["Title"] = "Dodaj stronę";
}

<div class="view-container">
    <div class="row justify-content-center">

        <div class="col-8">
            
            <div class="header-row">
                <div class="title-group">
                    <i class="bi bi-file-earmark-plus"></i>
                    <h1>Dodaj stronę</h1>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center gap-2 backBtn">
                    <i class="bi bi-arrow-left"></i> POWRÓT
                </a>
            </div>

            <div class="form-card">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <h5 class="section-title"><i class="bi bi-info-circle me-2"></i>Dane podstawowe strony</h5>
                    
                    <div class="row">
                        <div class="col-md-6 form-group mb-3">
                            <label asp-for="Title" class="control-label fw-bold mb-1"></label>
                            <input asp-for="Title" class="form-control input-area" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 form-group mb-3">
                            <label asp-for="LinkTitle" class="control-label fw-bold mb-1"></label>
                            <input asp-for="LinkTitle" class="form-control input-area" />
                            <span asp-validation-for="LinkTitle" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-3 form-group mb-3">
                            <label asp-for="Position" class="control-label fw-bold mb-1"></label>
                            <input asp-for="Position" class="form-control input-area" />
                            <span asp-validation-for="Position" class="text-danger small"></span>
                        </div>

                        <div class="col-md-3 form-group mb-3">
                            <label asp-for="PageMenuArea" class="control-label fw-bold mb-1"></label>
                            <select asp-for="PageMenuArea" asp-items="Html.GetEnumSelectList<PageMenuArea>()" class="form-select input-area"></select>
                            <span asp-validation-for="PageMenuArea" class="text-danger small"></span>
                        </div>
                        
                        <div class="col-md-6 form-group mb-3">
                            <label asp-for="HeroPhotoUrl" class="control-label fw-bold mb-1"></label>
                            <input asp-for="HeroPhotoUrl" class="form-control input-area" />
                            <span asp-validation-for="HeroPhotoUrl" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row align-content-center">
                        <div class="col-md-6 form-group mb-3">
                            <label asp-for="ControllerName" class="control-label fw-bold mb-1"></label>
                            <input asp-for="ControllerName" class="form-control input-area" />
                            <span asp-validation-for="ControllerName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 form-group mb-3">
                            <label asp-for="ActionName" class="control-label fw-bold mb-1"></label>
                            <input asp-for="ActionName" class="form-control input-area" />
                            <span asp-validation-for="ActionName" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="form-group form-check mb-4 mt-2 custom-checkbox">
                        <input class="form-check-input shadow-none" type="checkbox" asp-for="IsLinkCTA" />
                        <label class="form-check-label fw-bold" asp-for="IsLinkCTA">
                            @Html.DisplayNameFor(model => model.IsLinkCTA)
                        </label>
                    </div>
 
                    <h5 class="section-title mt-4"><i class="bi bi-layout-text-window-reverse me-2"></i>Treść</h5>
                    <div class="form-group mb-4">
                        <label asp-for="ShortDescription" class="control-label fw-bold mb-1"></label>
                        <textarea asp-for="ShortDescription" class="form-control input-area" rows="2"></textarea>
                        <span asp-validation-for="ShortDescription" class="text-danger small"></span>
                    </div>
                    <div class="form-group mb-4">
                        <label asp-for="Content" class="control-label fw-bold mb-1"></label>
                        <textarea asp-for="Content" class="form-control input-area" rows="8"></textarea>
                        <span asp-validation-for="Content" class="text-danger small"></span>
                    </div>

                    <hr class="my-4 segment-divider" />

                    <div class="d-flex justify-content-end align-items-center gap-3">
                        <a asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center gap-2 backBtn">
                            <i class="bi bi-arrow-left"></i> Anuluj
                        </a>
                        <button type="submit" class="createBtn border-0">
                            <i class="bi bi-check-lg me-1"></i> ZAPISZ
                        </button>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}