@model Firma.Data.Data.Hotel.Amenity

@{
    ViewData["Title"] = "Edytuj udogodnienie";
}

<div class="view-container">
    <div class="row justify-content-center">

        <div class="col-6">
            
            <div class="header-row">
                <div class="title-group">
                    <i class="bi bi-star-fill"></i>
                    <h1>Edytuj udogodnienie</h1>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center gap-2 backBtn">
                    <i class="bi bi-arrow-left"></i> POWRÓT
                </a>
            </div>
            
            <div class="form-card">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <input type="hidden" asp-for="Id" />

                    <h5 class="section-title"><i class="bi bi-info-circle me-2"></i>Dane podstawowe</h5>
                    
                    <div class="form-group mb-3">
                        <label asp-for="Name" class="control-label fw-bold mb-1"></label>
                        <input asp-for="Name" class="form-control input-area" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Icon" class="control-label fw-bold mb-1"></label>
                        <input asp-for="Icon" class="form-control input-area" />
                        <span asp-validation-for="Icon" class="text-danger small"></span>
                    </div>

                    <div class="form-group mb-4 mt-3">
                        <label asp-for="Description" class="control-label fw-bold mb-1"></label>
                        <textarea asp-for="Description" class="form-control input-area" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <hr class="my-4 segment-divider" />

                    <div class="d-flex justify-content-end align-items-center gap-3">
                        <a asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center gap-2 backBtn">
                            <i class="bi bi-arrow-left"></i> Anuluj
                        </a>
                        <button type="submit" class="createBtn border-0">
                            <i class="bi bi-check-lg me-1"></i> ZAPISZ
                        </button>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}