@model Firma.Data.Data.CMS.News
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env

@{
    ViewData["Title"] = "Szczegóły aktualności";
}

<div class="view-container">
    
    <div class="header-row">
        <div class="title-group">
            <i class="bi bi-info-square"></i>
            <h1>Szczegóły aktualności</h1>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center gap-2 backBtn">
            <i class="bi bi-arrow-left"></i> POWRÓT
        </a>
    </div>

    <div class="form-card">
        <div class="row gx-5">
            
            <div class="col-lg-8 mb-4 mb-lg-0">
                <h5 class="section-title"><i class="bi bi-layout-text-window-reverse me-2"></i>Treść aktualności</h5>

                <div class="form-group mb-3">
                    <label class="control-label fw-bold mb-1">@Html.DisplayNameFor(model => model.Title)</label>
                    <div class="form-control input-area d-flex align-items-center">
                        @Html.DisplayFor(model => model.Title)
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label class="control-label fw-bold mb-1">@Html.DisplayNameFor(model => model.LinkTitle)</label>
                    <div class="form-control input-area d-flex align-items-center">
                        @Html.DisplayFor(model => model.LinkTitle)
                    </div>
                </div>

                <div class="form-group mb-3 mt-4">
                    <label class="control-label fw-bold mb-1">@Html.DisplayNameFor(model => model.ContentSummary)</label>
                    <textarea class="form-control input-area" rows="3" readonly>@Model.ContentSummary</textarea>
                </div>

                <div class="form-group mb-4">
                    <label class="control-label fw-bold mb-1">@Html.DisplayNameFor(model => model.Content)</label>
                    <textarea class="form-control input-area" rows="6" readonly>@Model.Content</textarea>
                </div>
            </div>
            <div class="col-lg-4">
                <h5 class="section-title"><i class="bi bi-gear me-2"></i>Publikacja i media</h5>

                <div class="form-group mb-3">
                    <label class="control-label fw-bold mb-1">@Html.DisplayNameFor(model => model.Date)</label>
                    <div class="form-control input-area d-flex align-items-center">
                        @Html.DisplayFor(model => model.Date)
                    </div>
                </div>
                <div class="form-group mb-3">
                    <label class="control-label fw-bold mb-1">@Html.DisplayNameFor(model => model.PublishDate)</label>
                    <div class="form-control input-area d-flex align-items-center">
                        @Html.DisplayFor(model => model.PublishDate)
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label class="control-label fw-bold mb-1">@Html.DisplayNameFor(model => model.ImageUrl)</label>
                    <div class="form-control input-area d-flex align-items-center text-truncate" title="@Model.ImageUrl">
                        @Model.ImageUrl
                    </div>
                </div>

                <div class="photo-preview-box rounded border shadow-sm d-flex align-items-center justify-content-center overflow-hidden mb-4">
                    @{
                        var fileExists = File.Exists($"/images/{Model.ImageUrl}");
                        var imgSrc = fileExists ? $"/images/{Model.ImageUrl}" : "/images/no-image-placeholder.jpg";
                    }
                    <img src="@imgSrc" class="img-fluid w-100 photo-preview-img"/>
                </div>

            </div>

        </div>

        <hr class="my-4 segment-divider" />

        <div class="d-flex justify-content-end align-items-center gap-3">
            <a asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center gap-2 backBtn">
                <i class="bi bi-arrow-left"></i> Wróć
            </a>
            <a asp-action="Edit" asp-route-id="@Model?.Id" class="createBtn border-0">
                <i class="bi bi-pencil-square me-1"></i> EDYTUJ
            </a>
        </div>
    </div>

</div>