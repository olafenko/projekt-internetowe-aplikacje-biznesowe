@model Firma.Data.Data.CMS.News
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env

@{
    ViewData["Title"] = "Edytuj aktualność";
}

<div class="view-container">
    
    <div class="header-row">
        <div class="title-group">
            <i class="bi bi-pencil-square"></i>
            <h1>Edytuj aktualność</h1>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center gap-2 backBtn">
            <i class="bi bi-arrow-left"></i> POWRÓT
        </a>
    </div>

    <div class="form-card">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            
            <input type="hidden" asp-for="Id" />

            <div class="row gx-5">
                
                <div class="col-lg-8 mb-4 mb-lg-0">
                    <h5 class="section-title"><i class="bi bi-layout-text-window-reverse me-2"></i>Treść aktualności</h5>

                    <div class="form-group mb-3">
                        <label asp-for="Title" class="control-label fw-bold mb-1"></label>
                        <input asp-for="Title" class="form-control input-area" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="LinkTitle" class="control-label fw-bold mb-1"></label>
                        <input asp-for="LinkTitle" class="form-control input-area" />
                        <span asp-validation-for="LinkTitle" class="text-danger small"></span>
                    </div>

                    <div class="form-group mb-3 mt-4">
                        <label asp-for="ContentSummary" class="control-label fw-bold mb-1"></label>
                        <textarea asp-for="ContentSummary" class="form-control input-area" rows="3"></textarea>
                        <span asp-validation-for="ContentSummary" class="text-danger small"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Content" class="control-label fw-bold mb-1"></label>
                        <textarea asp-for="Content" class="form-control input-area" rows="6"></textarea>
                        <span asp-validation-for="Content" class="text-danger small"></span>
                    </div>
                </div>

                <div class="col-lg-4">
                    <h5 class="section-title"><i class="bi bi-gear me-2"></i>Publikacja i media</h5>

                    <div class="form-group mb-3">
                        <label asp-for="PublishDate" class="control-label fw-bold mb-1"></label>
                        <input asp-for="PublishDate" type="date" class="form-control input-area" />
                        <span asp-validation-for="PublishDate" class="text-danger small"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="ImageUrl" class="control-label fw-bold mb-1"></label>
                        <input asp-for="ImageUrl" id="imageUrlInput" class="form-control input-area" placeholder="np. zdjecie.jpg" />
                        <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                    </div>
                </div>

            </div>

            <hr class="my-4 segment-divider" />

            <div class="d-flex justify-content-end align-items-center gap-3">
                <a asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center gap-2 backBtn">
                    <i class="bi bi-arrow-left"></i> Anuluj
                </a>
                <button type="submit" class="createBtn border-0">
                    <i class="bi bi-check-lg me-1"></i> ZAPISZ ZMIANY
                </button>
            </div>
        </form>
    </div>
</div>

