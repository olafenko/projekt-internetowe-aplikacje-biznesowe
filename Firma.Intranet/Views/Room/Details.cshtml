@model Firma.Data.Data.Hotel.Room

@{
    ViewData["Title"] = "Szczegóły pokoju";
}

<div class="view-container">
    
    <div class="header-row">
        <div class="title-group">
            <i class="bi bi-info-square"></i>
            <h1>Szczegóły pokoju</h1>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center gap-2 backBtn">
            <i class="bi bi-arrow-left"></i> POWRÓT
        </a>
    </div>

    <div class="form-card">
        <div class="row gx-5">
            
            <div class="col-lg-7 mb-4 mb-lg-0">
                <h5 class="section-title"><i class="bi bi-door-open me-2"></i>Dane podstawowe pokoju</h5>
                
                <div class="row">
                    <div class="col-md-6 form-group mb-3">
                        <label class="control-label fw-bold mb-1">@Html.DisplayNameFor(model => model.Number)</label>
                        <div class="form-control input-area d-flex align-items-center">
                            @Html.DisplayFor(model => model.Number)
                        </div>
                    </div>

                    <div class="col-md-6 form-group mb-3">
                        <label class="control-label fw-bold mb-1">@Html.DisplayNameFor(model => model.Floor)</label>
                        <div class="form-control input-area d-flex align-items-center">
                            @Html.DisplayFor(model => model.Floor)
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 form-group mb-3">
                        <label class="control-label fw-bold mb-1">@Html.DisplayNameFor(model => model.RoomType)</label>
                        <div class="form-control input-area d-flex align-items-center">
                            @Html.DisplayFor(model => model.RoomType.Description)
                        </div>
                    </div>

                    <div class="col-md-6 form-group mb-3">
                        <label class="control-label fw-bold mb-1">@Html.DisplayNameFor(model => model.RoomStatus)</label>
                        <div class="form-control input-area d-flex align-items-center">
                            @Html.DisplayFor(model => model.RoomStatus)
                        </div>
                    </div>
                </div>

                <div class="form-group mb-3 mt-3">
                    <label class="control-label fw-bold mb-1">@Html.DisplayNameFor(model => model.Notes)</label>
                    <textarea class="form-control input-area" rows="6" readonly>@Model.Notes</textarea>
                </div>
            </div>
        </div>

        <hr class="my-4 segment-divider" />

        <div class="d-flex justify-content-end align-items-center gap-3">
            <a asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center gap-2 backBtn">
                <i class="bi bi-arrow-left"></i> Wróć
            </a>
            <a asp-action="Edit" asp-route-id="@Model?.Id" class="createBtn border-0">
                <i class="bi bi-pencil-square me-1"></i> EDYTUJ
            </a>
        </div>
    </div>

</div>