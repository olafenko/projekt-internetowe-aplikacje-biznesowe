@model Firma.Data.Data.CMS.Page;

@if(Model != null)
{
    @if (!string.IsNullOrEmpty(Model.HeroPhotoUrl))
    {
        <div class="page-hero" style="background-image: url('/content/@Model.HeroPhotoUrl');">
            <div class="hero-overlay"></div>
        </div>
    }

    <div class="container pt-5">

        <div class="row mb-5 text-center justify-content-center">
            <div class="col-12 col-lg-8">
                <h1 class="text-uppercase fw-bold mb-3" style="color: var(--accent-color); letter-spacing: 2px;">
                    @Model.Title
                </h1>
            
                <p class="lead page-descr">
                    @Model.ShortDescription
                </p>
            
                <hr class="mt-4 mx-auto" style="width: 100%; border-color: var(--accent-color); opacity: 0.3; border-width: 2px;" />
            </div>
        </div>

    </div>

}

