@model Firma.Data.Data.CMS.News

@{
    ViewData["Title"] = Model.Title;
    Layout = "~/Views/Shared/_SecondLayout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10 col-xl-8">

            <div class="mb-4">
                <a asp-action="Index" class="text-decoration-none" style="color: var(--accent-color); font-weight: 600; letter-spacing: 1px;">
                    <i class="bi bi-arrow-left me-2"></i>POWRÓT DO LISTY
                </a>
            </div>

            @{
                        
                var fileExists = File.Exists($"/content/{Model.ImageUrl}");
                var imgSrc = fileExists ? $"/content/{Model.ImageUrl}" : "/content/news1.jpg";
            }
            <div class="mb-5">
                <img src="@imgSrc" class="w-100" style="height: 450px; object-fit: cover; border-radius: 8px; border: 1px solid var(--segment-border-color);">
            </div>

            <div class="text-center mb-1">
                <span class="fw-bold d-block mb-3 text-uppercase" style="color: var(--accent-color); letter-spacing: 2px;">
                    <i class="bi bi-calendar3 me-2"></i>@Model.PublishDate.ToString("dd MMMM yyyy")
                </span>
                
                <h1 class="fw-bold mb-4" style="color: var(--main-text-color); font-size: 2.5rem; line-height: 1.3;">
                    @Model.Title
                </h1>
                
                <hr class="mx-auto" style="width: 75%; border-color: var(--accent-color); opacity: 0.5; border-width: 2px;" />
            </div>

            <div class="plain-text-content mb-5">
                @Model.Content
            </div>

        </div>
    </div>
</div>