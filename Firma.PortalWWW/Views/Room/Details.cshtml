@model Firma.Data.Data.Hotel.RoomType
@{
    ViewData["Title"] = Model.Name;
    Layout = "~/Views/Shared/_SecondLayout.cshtml";
}

@{
                        
    var fileExists = File.Exists($"/content/{Model.PhotoUrl}");
    var imgSrc = fileExists ? $"/content/{Model.PhotoUrl}" : "/content/default-room-image.jpg";
}

<div class="page-hero" style="background-image: url('@imgSrc'); height: 60vh;">
    <div class="hero-overlay"></div>
</div>

<div class="container py-5">
    <div class="row">
        
        <div class="col-lg-8 pe-lg-5">
            <h1 class="text-uppercase fw-bold mb-4" style="color: var(--accent-color); letter-spacing: 2px;">
                @Model.Name
            </h1>
            
            <p class="lead mb-5" style="color: var(--muted-text-color); line-height: 1.8;">
                @Model.Description
            </p>

            <h4 class="text-uppercase fw-bold mb-4" style="color: var(--main-text-color);">Udogodnienia w pokoju</h4>
            
            <div class="row g-4" style="color: var(--muted-text-color);">

                @await Html.PartialAsync("RoomAmenities", (IEnumerable<Firma.Data.Data.Hotel.Amenity>)ViewBag.AmenityModel)
               
            </div>
        </div>

        <div class="col-lg-4 mt-5 mt-lg-0">
            <div class="card room-card p-4 sticky-top" style="top: 120px;">
                <div class="card-body p-0">
                    
                    <h3 class="fw-bold mb-4" style="color: var(--accent-color);">
                        @Model.BasePrice.ToString("N0") Zł
                        <span style="color: var(--muted-text-color); font-size: 0.5em; font-weight: normal;">/ noc</span>
                    </h3>
                    
                    <ul class="list-unstyled mb-4" style="color: var(--muted-text-color); line-height: 2.5;">
                        <li class="border-bottom border-secondary" style="border-color: var(--segment-border-color) !important;">
                            <i class="bi bi-people-fill me-2" style="color: var(--accent-color);"></i>
                            Maksymalna liczba osób: <strong>@Model.MaxGuests</strong>
                        </li>
                        <li class="border-bottom border-secondary" style="border-color: var(--segment-border-color) !important;">
                            <i class="bi bi-clock me-2" style="color: var(--accent-color);"></i>
                            Zameldowanie: 15:00
                        </li>
                        <li>
                            <i class="bi bi-clock-history me-2" style="color: var(--accent-color);"></i>
                            Wymeldowanie: 11:00
                        </li>
                    </ul>

                    <a href="#" class="btn btn-action w-100 py-3 text-uppercase">
                        Zarezerwuj teraz
                    </a>
                    
                </div>
            </div>
        </div>
        
    </div>
</div>