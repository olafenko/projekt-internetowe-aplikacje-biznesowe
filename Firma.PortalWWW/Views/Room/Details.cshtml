@model Firma.Data.Data.Hotel.RoomType
@{
    ViewData["Title"] = Model.Name;
    Layout = "~/Views/Shared/_SecondLayout.cshtml";
}

@{
                        
    var fileExists = File.Exists($"/content/{Model.PhotoUrl}");
    var imgSrc = fileExists ? $"/content/{Model.PhotoUrl}" : "/content/default-room-image.jpg";
}

<div class="page-hero" style="background-image: url('@imgSrc'); height: 60vh;">
    <div class="hero-overlay"></div>
</div>

<div class="container py-5">
    <div class="row">
        <div class="col-lg-3 mt-5 mt-lg-0">
            <div class="card room-card p-4 sticky-top" style="top: 120px;">
                <div class="card-body p-0">
                    
                    <h3 class="fw-bold mb-4 text-center" style="color: var(--accent-color);">
                        @Model.BasePrice.ToString("N0") zł
                        <span style="color: var(--muted-text-color); font-size: 16px; font-weight: normal;">/ noc</span>
                    </h3>
                    
                    <a href="#" class="btn btn-action w-100 py-3 text-uppercase">
                        Rezerwuj teraz
                    </a>
                    
                </div>
            </div>
        </div>
        <div class="col-lg-9 px-lg-5">
            <h1 class="text-uppercase fw-bold mb-3" style="color: var(--accent-color); letter-spacing: 2px;">
                @Model.Name
            </h1>
            
            <hr class="mb-4" style="border-color: var(--segment-border-color); opacity: 1;" />

            <h5 class="text-uppercase fw-bold mb-3" style="color: var(--main-text-color);">Podstawowe informacje</h5>
            
            <div class="d-flex flex-wrap gap-4 mb-5" style="color: var(--muted-text-color);">
                <div class="d-flex align-items-center">
                    <i class="bi bi-people-fill fs-4 me-2" style="color: var(--accent-color);"></i>
                    <span class="fs-6">Max. osób: <strong style="color: var(--main-text-color);">@Model.MaxGuests</strong></span>
                </div>
                
                <div class="d-flex align-items-center">
                    <i class="bi bi-moon-stars-fill fs-4 me-2" style="color: var(--accent-color);"></i>
                    <span class="fs-6">Liczba łóżek: <strong style="color: var(--main-text-color);">@Model.BedCount</strong></span>
                </div>
            </div>
           
            <p class="lead mb-5" style="color: var(--muted-text-color); line-height: 1.8;">
                @Model.Description
            </p>

            <h5 class="text-uppercase fw-bold mb-4" style="color: var(--main-text-color);">Udogodnienia pokoju</h5>
            
            <div class="row g-4" style="color: var(--muted-text-color);">

                @await Html.PartialAsync("RoomAmenities", (IEnumerable<Firma.Data.Data.Hotel.Amenity>)ViewBag.AmenityModel)
               
            </div>
        </div>

       
        
    </div>
</div>